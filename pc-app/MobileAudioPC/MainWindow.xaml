<Window x:Class="MobileAudioPC.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:ui="clr-namespace:MobileAudioPC.UI"
        Title="MobileAudio Streamer" 
        Height="500" Width="700"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource PrimaryHueMidBrush}" Padding="20,16">
            <Grid>
                <TextBlock Text="MobileAudio Streamer" 
                           FontSize="24" FontWeight="Bold" 
                           Foreground="White" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusEllipse" Width="12" Height="12" Fill="Gray" Margin="0,0,8,0"/>
                    <TextBlock x:Name="StatusText" Text="Остановлено" FontSize="14" Foreground="White"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- IP Address -->
            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="IP-адрес для подключения" FontSize="14" Margin="0,0,0,8" Opacity="0.7"/>
                <Grid>
                    <TextBox x:Name="IpTextBox" 
                             materialDesign:HintAssist.Hint="192.168.1.x"
                             FontSize="16" Padding="12,8"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                    <Button x:Name="CopyIpButton" 
                            Content="Копировать" 
                            HorizontalAlignment="Right"
                            Margin="0,0,4,0"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Click="CopyIpButton_Click"/>
                </Grid>
            </StackPanel>

            <!-- Target IP -->
            <StackPanel Grid.Row="1" Margin="0,0,0,16">
                <TextBlock Text="IP телефона (или автообнаружение)" FontSize="14" Margin="0,0,0,8" Opacity="0.7"/>
                <Grid>
                    <TextBox x:Name="TargetIpTextBox" 
                             materialDesign:HintAssist.Hint="192.168.1.x"
                             FontSize="16" Padding="12,8"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                </Grid>
            </StackPanel>

            <!-- Controls -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,16">
                <Button x:Name="StartButton" 
                        Content="СТАРТ" 
                        Width="140" Height="44"
                        Background="{DynamicResource PrimaryHueMidBrush}"
                        Foreground="White"
                        materialDesign:ButtonAssist.CornerRadius="22"
                        Click="StartButton_Click"/>
                <Button x:Name="StopButton" 
                        Content="СТОП" 
                        Width="140" Height="44"
                        Margin="16,0,0,0"
                        Background="{DynamicResource MaterialDesignValidationErrorBrush}"
                        Foreground="White"
                        materialDesign:ButtonAssist.CornerRadius="22"
                        Click="StopButton_Click"
                        IsEnabled="False"/>
            </StackPanel>

            <!-- Visualizer -->
            <Border Grid.Row="3" 
                    Background="#1E1E1E" 
                    CornerRadius="12" 
                    Padding="16">
                <Grid>
                    <TextBlock Text="Аудио визуализатор" 
                               FontSize="12" Opacity="0.5" 
                               VerticalAlignment="Top" HorizontalAlignment="Left"/>
                    <ui:AudioVisualizer x:Name="Visualizer" 
                                        VerticalAlignment="Stretch" 
                                        HorizontalAlignment="Stretch"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#151515" Padding="20,12">
            <TextBlock Text="MobileAudio v1.0 | Локальное аудио стриминг" 
                       FontSize="12" Opacity="0.5" HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</Window>

