<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="MobileAudioPC" Manufacturer="MobileAudio" Version="1.0.0.0" UpgradeCode="a1b2c3d4-e5f6-7890-abcd-ef1234567890">
    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="Main" Title="MobileAudioPC" Level="1">
      <ComponentGroupRef Id="INSTALLFOLDERFiles" />
      <ComponentRef Id="ApplicationShortcut" />
    </Feature>

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="MobileAudioPC" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="MobileAudioPC">
        <Component Id="ApplicationShortcut" Guid="b2c3d4e5-f6a7-8901-bcde-f23456789012">
          <Shortcut Id="ApplicationStartMenuShortcut"
                    Name="MobileAudioPC"
                    Description="MobileAudio Streamer"
                    Target="[INSTALLFOLDER]MobileAudioPC.exe"
                    WorkingDirectory="INSTALLFOLDER" />
          <RemoveFolder Id="ApplicationProgramsFolder" On="uninstall" />
          <RegistryValue Root="HKCU" Key="Software\MobileAudio\MobileAudioPC" Name="installed" Type="integer" Value="1" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>
  </Package>
</Wix>
