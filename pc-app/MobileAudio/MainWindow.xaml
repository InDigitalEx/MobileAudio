<Window x:Class="MobileAudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:ui="clr-namespace:MobileAudio.UI"
        Title="Mobile Audio"
        Icon="Assets/app-icon.png"
        Height="640" Width="720"
        Background="#FF121212"
        Foreground="White"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Background" Value="#FF00897B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="22" 
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF00BFA5"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#FF444444"/>
                    <Setter Property="Opacity" Value="0.6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
            <Setter Property="Background" Value="#FFD32F2F"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFE57373"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FlatButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FF80CBC4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CustomTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="#FF80CBC4"/>
            <Setter Property="BorderBrush" Value="#FF333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                          Margin="{TemplateBinding Padding}"
                                          Focusable="false"
                                          HorizontalScrollBarVisibility="Hidden" 
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#FF00897B"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#FF00897B" Padding="20,16">
            <Grid>
                <TextBlock Text="Mobile Audio"
                           FontSize="24" FontWeight="Bold" 
                           Foreground="White" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusEllipse" Width="12" Height="12" Fill="Gray" Margin="0,0,8,0"/>
                    <TextBlock x:Name="StatusText" Text="Остановлено" FontSize="14" Foreground="White"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="140"/>
                <RowDefinition Height="120"/>
            </Grid.RowDefinitions>

            <!-- IP Address -->
            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="IP-адрес для подключения" FontSize="13" Margin="0,0,0,8" Opacity="0.6"/>
                <Grid>
                    <TextBox x:Name="IpTextBox" 
                             Style="{StaticResource CustomTextBox}"/>
                    <Button x:Name="CopyIpButton" 
                            Content="Копировать" 
                            HorizontalAlignment="Right"
                            Margin="0,0,4,0"
                            Style="{StaticResource FlatButton}"
                            Click="CopyIpButton_Click"/>
                </Grid>
            </StackPanel>

            <!-- Target IP -->
            <StackPanel Grid.Row="1" Margin="0,0,0,8">
                <TextBlock Text="IP телефона" FontSize="13" Margin="0,0,0,8" Opacity="0.6"/>
                <Grid>
                    <TextBox x:Name="TargetIpTextBox" 
                             Style="{StaticResource CustomTextBox}"/>
                </Grid>
            </StackPanel>

            <!-- Discovered Devices -->
            <StackPanel Grid.Row="2" Margin="0,0,0,16">
                <TextBlock Text="Найденные устройства" FontSize="13" Margin="0,0,0,8" Opacity="0.6"/>
                <Border Background="#FF1E1E1E" CornerRadius="10" Padding="8" MaxHeight="120">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="DevicesPanel">
                            <TextBlock Text="Поиск устройств..." 
                                       FontSize="13" Opacity="0.4" 
                                       HorizontalAlignment="Center"
                                       Margin="0,8,0,8"
                                       x:Name="NoDevicesText"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </StackPanel>

            <!-- Controls -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,16">
                <Button x:Name="StartButton" 
                        Content="СТАРТ" 
                        Width="140" Height="48"
                        Style="{StaticResource RoundedButton}"
                        Click="StartButton_Click"/>
                <Button x:Name="StopButton" 
                        Content="СТОП" 
                        Width="140" Height="48"
                        Margin="16,0,0,0"
                        Style="{StaticResource DangerButton}"
                        Click="StopButton_Click"
                        IsEnabled="False"/>
            </StackPanel>

            <!-- Visualizer -->
            <Border Grid.Row="4" 
                    Background="#FF1E1E1E" 
                    CornerRadius="12" 
                    Padding="16" Margin="0,0,0,8">
                <Grid>
                    <TextBlock Text="Аудио визуализатор" 
                               FontSize="11" Opacity="0.4" 
                               VerticalAlignment="Top" HorizontalAlignment="Left"/>
                    <ui:AudioVisualizer x:Name="Visualizer" 
                                        VerticalAlignment="Stretch" 
                                        HorizontalAlignment="Stretch"
                                        Margin="0,20,0,0"/>
                </Grid>
            </Border>

            <!-- Logger -->
            <Border Grid.Row="5" 
                    Background="#FF151515" 
                    CornerRadius="8" 
                    Padding="8">
                <ScrollViewer x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto">
                    <TextBox x:Name="LogTextBox"
                             Background="Transparent"
                             Foreground="#FF888888"
                             FontFamily="Consolas"
                             FontSize="11"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             BorderThickness="0"/>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#FF151515" Padding="20,12">
            <TextBlock Text="MobileAudio v1.0 | Локальное аудио стриминг" 
                       FontSize="11" Opacity="0.4" HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
